pipeline {
    agent {
        label 'agent1'
    }

    stages{
        stage("AppCode Checkout"){
            steps{
                git branch:'jenkis-learning', url: 'https://github.com/prateekkumawat/kubernetes-12-ay.git'
            }
        }

        stage("Prepareserver"){
            steps{
                sh '''
                sudo yum install httpd -y 
                sudo systemctl start httpd 
                sudo systemctl enable httpd '''
            }
        }

        stage("CopyContent"){
            steps{
                sh 'sudo cp -rvf $WORKSPACE/webapp/src/  /var/www/html'
            }
        }
    }
}