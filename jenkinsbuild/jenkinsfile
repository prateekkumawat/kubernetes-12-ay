pipeline {
    agent {
        label 'agent1'
    }
     

    stages{
        stage("Clean Workspace") { 
            steps {
                cleanWs()
            }
        }
        
        stage("AppCode Checkout"){
            steps{
                git branch: 'springapp', url: 'https://github.com/prateekkumawat/kubernetes-12-ay.git'
            }
        }

        stage("Init"){
            steps {
                dir('terraform-basic/'){
                sh " terraform init "
                } 
            }
        }
        stage("Plan"){
            steps {
                dir('terraform-basic/'){
                    sh " terraform plan "
                } 
            }
        } 
        stage("Apply"){
            steps {
                dir('terraform-basic/'){
                    sh " terraform apply --auto-approve "
                } 
            }
        }    

        stage("Teams Notification") {
            steps {
                script {
                    withCredentials([string(credentialsId: 'TEAMS_WEBHOOK', variable: 'WEBHOOK_URL')]) {
                        sh """
                        curl -H 'Content-Type: application/json' \
                        -d '{
                        "@type": "MessageCard",
                        "@context": "http://schema.org/extensions",
                        "summary": "Jenkins Build",
                        "themeColor": "00FF00",
                        "title": "Jenkins Job: ${env.JOB_NAME}",
                        "sections": [{
                            "facts": [
                                { "name": "🟢 **Status**", "value": "**SUCCESS ✅**" },
                                { "name": "🔢 **Build**", "value": "**#${env.BUILD_NUMBER}**" },
                                { "name": "🌿 **Branch / Tag**", "value": "**${env.GIT_BRANCH ?: params.GIT_REF}**" },
                                { "name": "🔗 **Build URL**", "value": "[**Open Build**](${env.BUILD_URL})" }
                            ],
                            "text": "🚀 **Build completed successfully!**"
                        }]
                        }' \
                        \$WEBHOOK_URL
                        """
                    }
                }
            }
        }

    }    
}   