pipeline {
    agent {
        label 'agent1'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_CREDS = credentials('docker-creds')
    }

    stages{
        stage("Clean WorkSpaace") {
            steps{
              cleanWs()
            }
        }

        stage("AppCode Checkout"){
            steps {
                git branch:'project1', url:' https://github.com/prateekkumawat/jenkins-ci-8am.git'
            }
        }
        
        stage("SonarAnalysis"){
            steps{
                dir('Application-Code/'){
                    withSonarQubeEnv('sonar-server') {
                      sh ''' $SCANNER_HOME/bin/sonar-scanner \
                      -Dsonar.projectName=netflix-app \
                      -Dsonar.projectKey=netflix-app '''
                    }
                }     
            }
        }   

        stage("Sonar QualityGate"){
            steps{
                script {
                  waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token' 
                }
            }
        }

        stage("CreateImage"){
            steps{
                dir('Application-Code/'){
                    sh 'docker build -t prateekkumawat/netflix:0.1.1 . '
                }            
            }
        }
        
        stage("Image scan"){
            steps{
              sh 'trivy image prateekkumawat/netflix:0.1.1 >> scanreport.txt '
            }
        }

        stage("push Image"){
          steps {
               sh 'docker login -u $DOCKER_CREDS_USR -p $DOCKER_CREDS_PSW '
               sh ' docker push prateekkumawat/netflix:0.1.1 '
            }
        }
         
 
        stage("Notification") {
            steps {
                script {
                    withCredentials([string(credentialsId: 'TEAMS_WEBHOOK', variable: 'WEBHOOK_URL')]) {
                        sh """
                        curl -H 'Content-Type: application/json' \
                        -d '{
                        "@type": "MessageCard",
                        "@context": "http://schema.org/extensions",
                        "summary": "Jenkins Build",
                        "themeColor": "00FF00",
                        "title": "Jenkins Job: ${env.JOB_NAME}",
                        "sections": [{
                            "facts": [
                                { "name": "🟢 **Status**", "value": "**SUCCESS ✅**" },
                                { "name": "🔢 **Build**", "value": "**#${env.BUILD_NUMBER}**" },
                                { "name": "🌿 **Branch / Tag**", "value": "**${env.GIT_BRANCH ?: params.GIT_REF}**" },
                                { "name": "🟢 **image**", "value": "**prateekkumawat/pythonapp:v0.0.1" },
                                { "name": "🔗 **Build URL**", "value": "[**Open Build**](${env.BUILD_URL})" }
                            ],
                            "text": "🚀 **Build completed successfully!**"
                        }]
                        }' \
                        \$WEBHOOK_URL
                        """
                    }
                }
            }
        }
   }
}    