pipeline {
    agent {
        label 'agent1'
    }

    environment {
        S3_BUCKET = 'amazon-jenkins-web'
        AWS_REGION = 'ap-south-2'
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages{
        stage("AppCode Checkout"){
            steps{
                git branch: 's3/webapp/sonar', url: 'https://github.com/prateekkumawat/kubernetes-12-ay.git'
            }
        }

        stage ("Sonar Analysis"){
            steps{
                dir('src/'){
                    withSonarQubeEnv('sonar-server') {
                       sh ''' 
                         $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=s3-webapp-sonar \
                        -Dsonar.projectName=s3-webapp-sonar  '''
                    }
                }             
            }
        }

        stage("Sonar QualityGate"){
            steps{
                script {
                  waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token' 
                }
            }
        }

        stage("Deploy Code to S3"){
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding', 
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                    aws s3 sync $WORKSPACE/src/ s3://$S3_BUCKET --delete
                    '''
                }
            }
        }
        stage("Teams Notification") {
            steps {
                script {
                    withCredentials([string(credentialsId: 'TEAM_WEBHOOK', variable: 'WEBHOOK_URL')]) {
                        sh """
                        curl -H 'Content-Type: application/json' \
                        -d '{
                        "@type": "MessageCard",
                        "@context": "http://schema.org/extensions",
                        "summary": "Jenkins Build",
                        "themeColor": "00FF00",
                        "title": "Jenkins Job: ${env.JOB_NAME}",
                        "sections": [{
                            "facts": [
                                { "name": "🟢 **Status**", "value": "**SUCCESS ✅**" },
                                { "name": "🔢 **Build**", "value": "**#${env.BUILD_NUMBER}**" },
                                { "name": "🌿 **Branch / Tag**", "value": "**${env.GIT_BRANCH ?: params.GIT_REF}**" },
                                { "name": "🔗 **Build URL**", "value": "[**Open Build**](${env.BUILD_URL})" }
                            ],
                            "text": "🚀 **Build completed successfully!**"
                        }]
                        }' \
                        \$WEBHOOK_URL
                        """
                    }
                }
            }
        }

    }    
}   